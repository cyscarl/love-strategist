# 数据库文件（二进制，运行时数据）
data/
*.db
*.sqlite
*.sqlite3

# 日志文件（运行时输出）
logs/
*.log

# 临时文件（开发调试用）
temp/

# 用户配置文件（含 API Key 等敏感信息）
config/config.yaml

# Python 缓存与编译产物
__pycache__/
*.pyc
*.pyo
*.pyd
.eggs/
*.egg-info/
*.egg

# 构建与分发产物
dist/
build/
*.spec

# 虚拟环境
venv/
.venv/
env/
.env/

# IDE 与编辑器配置
.vscode/
.idea/
*.swp
*.swo
*~

# 版本控制
.git/

# 操作系统生成文件
Thumbs.db
.DS_Store
Desktop.ini

# 图片等二进制资源（如需查看 UI 布局请参考 docs/ui布局参考.md）
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.bmp

# 打包相关
*.exe
*.dmg
*.pkg
